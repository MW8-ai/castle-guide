{
  "name": "castle-guide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Home Guide — fun all-in-one home maintenance helper for homeowners.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "spike:iso": "vite --config spikes/iso-canvas/vite.config.ts",
    "ci": "npm run typecheck && npm run validate:schemas && npm run test && npm run build"
  },
  "dependencies": {
    "@preact/signals": "^2.0.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dexie": "^4.4.4",
    "jszip": "^3.10.1",
    "preact": "^10.26.4",
    "preact-router": "^4.1.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.13.10",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  }
}
